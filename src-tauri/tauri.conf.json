{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Smart.Tech.PDV",
  "version": "2.0.9",
  "identifier": "com.smarttech.pdv",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build && node ./scripts/check-updater.mjs",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Smart Tech PDV",
        "label": "main",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 720,
        "center": true,
        "maximized": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "msi"
    ],
    "publisher": "Smart Tech",
    "category": "Business",
    "shortDescription": "ERP/PDV desktop premium para loja de calcados",
    "windows": {
      "wix": {
        "language": [
          "en-US"
        ]
      }
    },
    "icon": [
      "icons/icon-32.png",
      "icons/icon-128.png",
      "icons/icon-512.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1MDYwQUZCN0IwRUY0REUKUldUZTlBNTcrd29HbFJGcU1EdnRGSlBZMFdTRVQzZWRWRUwyWmNvUFAwK1UwZHJ3N0oyaTY0aWgK",
      "endpoints": [
        "https://github.com/muinkadfy-cmd/smart-tech-pdv/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
